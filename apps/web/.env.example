# ── Clerk (dashboard auth) ─────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── API ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WIDGET_URL=http://localhost:5173  # Widget bundle host (Vite dev or CDN)

# ── Supabase (Realtime for inbox) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=              # from `supabase status`

# ── Paddle (client-side checkout overlay) ─────────────────
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...    # Paddle client-side token (sandbox or production)
