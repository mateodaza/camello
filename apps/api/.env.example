# ── Server ──────────────────────────────────────────────────
PORT=4000
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Dashboard origin (CORS)

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase (module executor broadcast) ───────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=              # from `supabase status`

# ── Clerk (dashboard auth) ─────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Widget (anonymous visitor JWT) ─────────────────────────
WIDGET_JWT_SECRET=                      # any random 32+ char string

# ── WhatsApp Cloud API ─────────────────────────────────────
WA_APP_SECRET=                          # Meta App Secret (HMAC verification)
WA_VERIFY_TOKEN=                        # Your custom webhook verify token

# ── LLM ────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
