# ── Server ──────────────────────────────────────────────────
PORT=4000
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Dashboard origin (CORS)

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase (module executor broadcast) ───────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=              # from `supabase status`

# ── Clerk (dashboard auth + webhooks) ─────────────────────
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...            # Svix signing secret from Clerk webhook config

# ── Widget (anonymous visitor JWT) ─────────────────────────
WIDGET_JWT_SECRET=                      # any random 32+ char string

# ── WhatsApp Cloud API ─────────────────────────────────────
WA_APP_SECRET=                          # Meta App Secret (HMAC verification)
WA_VERIFY_TOKEN=                        # Your custom webhook verify token

# ── Paddle Billing ────────────────────────────────────────
PADDLE_API_KEY=test_...                  # Paddle API key (sandbox or production)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...     # Paddle webhook signing secret
PADDLE_ENVIRONMENT=sandbox               # sandbox | production
PADDLE_PRICE_ID_STARTER=pri_...          # Price ID for Starter plan
PADDLE_PRICE_ID_GROWTH=pri_...           # Price ID for Growth plan
PADDLE_PRICE_ID_SCALE=pri_...            # Price ID for Scale plan

# ── LLM ────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
