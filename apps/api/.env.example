# ── Server ──────────────────────────────────────────────────
PORT=4000
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Dashboard origin (CORS)
API_URL=http://localhost:4000               # Public API base URL (used for webhook config, WhatsApp retries)

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Service-role connection (bypasses RLS). Used for cross-tenant jobs and queue claims only.
DATABASE_URL_SERVICE_ROLE=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase (module executor broadcast) ───────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=              # from `supabase status`

# ── Clerk (dashboard auth + webhooks) ─────────────────────
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...            # Svix signing secret from Clerk webhook config

# ── Widget (anonymous visitor JWT) ─────────────────────────
WIDGET_JWT_SECRET=                      # any random 32+ char string

# ── WhatsApp Cloud API ─────────────────────────────────────
WA_APP_SECRET=                          # Meta App Secret (HMAC verification)
WA_VERIFY_TOKEN_SECRET=                 # Your custom webhook verify token (was WA_VERIFY_TOKEN)

# ── Internal security ──────────────────────────────────────
INTERNAL_RETRY_SECRET=                  # Shared secret for /api/internal/* routes (any 32+ char string)

# ── Paddle Billing ────────────────────────────────────────
PADDLE_API_KEY=test_...                  # Paddle API key (sandbox or production)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...     # Paddle webhook signing secret
PADDLE_ENVIRONMENT=sandbox               # sandbox | production
PADDLE_PRICE_ID_STARTER=pri_...          # Price ID for Starter plan
PADDLE_PRICE_ID_GROWTH=pri_...           # Price ID for Growth plan
PADDLE_PRICE_ID_SCALE=pri_...            # Price ID for Scale plan

# ── LLM ────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Email (transactional) ──────────────────────────────────
RESEND_API_KEY=re_...                   # Resend API key for transactional emails
