{
  "name": "camello",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "db:generate": "turbo db:generate --filter=@camello/db",
    "db:migrate": "turbo db:migrate --filter=@camello/db",
    "db:push": "turbo db:push --filter=@camello/db"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "turbo": "^2.8.9",
    "typescript": "^5.7.3"
  }
}
